{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tech-okr-manager",
  "main": "worker/index.ts",
  "account_id": "58e8b90a519f82d104d35ce5872ab049",
  "compatibility_date": "2026-06-05",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tech-okr-db",
      "database_id": "1878f017-27e9-433a-a853-11323f5b5ffa"
    }
  ]
}
